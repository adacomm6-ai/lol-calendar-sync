{
  "name": "lol-data-system",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev-local.js",
    "build": "npm run prepare:local && next build --webpack",
    "start:local:prod": "node scripts/start-local-prod.js",
    "prod:local": "npm run build && npm run start:local:prod",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "postinstall": "node node_modules/prisma/build/index.js generate --schema prisma/schema.local.prisma",
    "dev:local": "node scripts/dev-local.js",
    "dev:cloud": "node scripts/dev-cloud.js",
    "prepare:local": "node scripts/prepare-local-if-needed.js",
    "prepare:local:force": "node scripts/migrate-local-player-model.js && node node_modules/prisma/build/index.js generate --schema prisma/schema.local.prisma && node node_modules/prisma/build/index.js db push --schema prisma/schema.local.prisma --skip-generate",
    "prepare:cloud": "node node_modules/prisma/build/index.js generate --schema prisma/schema.prisma",
    "fix:local:game-version": "node scripts/fix-local-game-version-coverage.js",
    "predeploy:cloud:check": "node scripts/predeploy-cloud-readonly-check.js",
    "cloud:fix:gvr-players": "node scripts/sync-cloud-gvr-and-dedupe-players.js",
    "cloud:fix:gvr-players:dry": "node scripts/sync-cloud-gvr-and-dedupe-players.js --dry-run",
    "cloud:backfill:match-version": "node scripts/backfill-cloud-match-versions.js",
    "cloud:fix:player-links": "node scripts/fix-cloud-player-links-after-dedupe.js",
    "cloud:fix:player-links:dry": "node scripts/fix-cloud-player-links-after-dedupe.js --dry-run",
    "sync:cloud-to-local:full": "npm run prepare:local && node scripts/pull-from-cloud.js --full-replace",
    "check:local:data": "node scripts/check-local-data-complete.js",
    "test:local:oneclick": "npm run prepare:local && npm run check:local:data",
    "check:cloud-local:consistency": "node scripts/check-cloud-local-consistency.js",
    "package:local-transfer": "powershell -ExecutionPolicy Bypass -File package_project.ps1",
    "package:local-transfer:ready": "powershell -ExecutionPolicy Bypass -File package_project.ps1 -IncludeReady",
    "check:sync:integrity": "node scripts/verify-sync-integrity.js",
    "check:sync:integrity:strict": "node scripts/verify-sync-integrity.js --since-hours=24",
    "fix:sync:dedupe:snapshots:dry": "node scripts/dedupe-player-snapshots.js",
    "fix:sync:dedupe:snapshots": "node scripts/dedupe-player-snapshots.js --apply"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "5.10.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.91.1",
    "@types/mime": "^3.0.4",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "lucide-react": "^0.563.0",
    "mime": "^4.1.0",
    "next": "16.1.6",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "recharts": "^3.6.0",
    "sharp": "^0.34.5",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/d3-color": "^3.1.3",
    "@types/d3-path": "^3.1.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.2.3",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "pg": "^8.18.0",
    "playwright": "^1.58.2",
    "prisma": "5.10.0",
    "remeda": "^2.33.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "overrides": {
    "react": "19.0.0",
    "react-dom": "19.0.0"
  }
}
