                                    <>
                                        <p className="font-bold text-green-400 mb-2">{playoffRefreshResult.message}</p>
                                        <div className="space-y-1">
                                            {playoffRefreshResult.details?.map((d: string, i: number) => (
                                                <p key={i} className="text-xs text-slate-300">
                                                    {d}
                                                </p>
                                            ))}
                                        </div>
