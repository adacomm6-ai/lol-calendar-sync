                        <div className="flex justify-end gap-3 mt-auto pt-4 border-t border-slate-800">
                            <button
                                onClick={() => {
                                    setIsPlayoffRefreshOpen(false);
                                    setPlayoffRefreshResult(null);
                                }}
                                className="text-slate-400 hover:text-white px-4 py-2"
                            >
