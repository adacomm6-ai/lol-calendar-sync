export async function importMatches(data: string, region: string, defaultStage: string = 'Regular Season') {
    try {
        let matchesToInsert: Array<{
            startTime: string;
            teamAId: string;
            teamBId: string;
            status: string;
            format: string;
            tournament: string;
            stage: string;
        }> = [];

        try {
            const json = JSON.parse(data);
            if (Array.isArray(json)) {
                matchesToInsert = json.map((item) => ({
                    ...item,
                    stage: (item.stage || defaultStage || 'Regular Season').trim(),
                }));
            }
        } catch (e) {
            const lines = data.split('\n').filter(l => l.trim());

            const teams = await prisma.team.findMany({ select: { id: true, name: true, shortName: true } });
            const teamMap = new Map();
            teams.forEach(t => {
                if (t.shortName) teamMap.set(t.shortName.toLowerCase(), t.id);
                teamMap.set(t.name.toLowerCase(), t.id);
            });

            for (const line of lines) {
                const parts = line.trim().split(/\s+/);
                if (parts.length >= 4) {
                    const dateStr = parts[0];
                    const timeStr = parts[1];
                    let teamAStr = parts[2];
                    let teamBStr = parts[parts.length - 1];

                    if (parts.includes('vs')) {
                        const vsIndex = parts.indexOf('vs');
                        teamAStr = parts.slice(2, vsIndex).join(' ');
                        teamBStr = parts.slice(vsIndex + 1).join(' ');
                    }

                    const teamAId = teamMap.get(teamAStr.toLowerCase());
                    const teamBId = teamMap.get(teamBStr.toLowerCase());

                    if (teamAId && teamBId) {
                        const isoString = `${dateStr}T${timeStr}:00+08:00`;

                        matchesToInsert.push({
                            startTime: isoString,
                            teamAId,
                            teamBId,
                            status: 'SCHEDULED',
                            format: 'BO3',
                            tournament: `2026 ${region} Split 1`,
                            stage: (defaultStage || 'Regular Season').trim()
                        });
                    }
                }
            }
        }

        if (matchesToInsert.length === 0) {
            return { success: false, error: 'No valid matches found to import.' };
        }

                const operations: any[] = [];
        for (const m of matchesToInsert) {
            const startAt = new Date(m.startTime);
            const autoVersion = await resolveVersionForPayload({
                startTime: startAt,
                tournament: m.tournament,
                regionHint: region,
            });

            operations.push(
                prisma.match.create({
                    data: {
                        startTime: startAt,
                        teamAId: m.teamAId,
                        teamBId: m.teamBId,
                        status: m.status,
                        format: m.format,
                        tournament: m.tournament,
                        stage: m.stage,
                        gameVersion: autoVersion || null,
                    }
                })
            );
        }

        await prisma.$transaction(operations);

        revalidatePath('/schedule');
        revalidatePath('/admin/schedule');
        return { success: true, count: matchesToInsert.length };

    } catch (e: any) {
        return { success: false, error: e.message };
    }
}

import { fetchTournamentMatches, resolveTournament, fetchPlayoffResults } from '@/lib/leaguepedia';

export async function importFromWiki(input: string) {
    try {
        const tournamentName = await resolveTournament(input);
        const wikiMatches = await fetchTournamentMatches(tournamentName);
        if (wikiMatches.length === 0) {
            return { success: false, error: `No future matches found for tournament '${tournamentName}' (Input: ${input}).` };
        }

        // Map teams
        const teams = await prisma.team.findMany({ select: { id: true, name: true, shortName: true } });
        const teamMap = new Map();
        teams.forEach(t => {
            if (t.shortName) teamMap.set(t.shortName.toLowerCase(), t.id);
            teamMap.set(t.name.toLowerCase(), t.id);
        });

        const matchesToInsert: Array<{
            startTime: string;
            teamAId: string;
            teamBId: string;
            status: string;
            format: string;
            tournament: string;
            stage: string;
        }> = [];
        const skipped: string[] = [];

        for (const m of wikiMatches) {
            const teamAId = teamMap.get(m.team1.toLowerCase());
            const teamBId = teamMap.get(m.team2.toLowerCase());

            if (teamAId && teamBId) {
                // Leaguepedia returns UTC string "YYYY-MM-DD HH:mm:ss"
                // Our system treats ISO strings with offset.
                // "2026-02-01 09:00:00" (UTC) -> "2026-02-01T09:00:00Z"
                const isoString = m.date.replace(' ', 'T') + 'Z';

                // Check if exists?
                // For simplicity, we just prepare them. Application logic or UI should confirm.
                // Or we just insert and rely on manual conflict check or distinct?
                // Let's check existence by time and teams to avoid duplicates.
                const exists = await prisma.match.findFirst({
                    where: {
                        startTime: new Date(isoString),
                        OR: [
                            { teamAId: teamAId, teamBId: teamBId },
                            { teamAId: teamBId, teamBId: teamAId }
                        ]
                    }
                });

                if (!exists) {
                    matchesToInsert.push({
                        startTime: isoString,
                        teamAId,
                        teamBId,
                        status: 'SCHEDULED',
                        format: 'BO3', // Wiki default?
                        tournament: m.tournament,
                        stage: 'Regular Season' // Wiki might not give stage clearly in this query
                    });
                } else {
                    skipped.push(`${m.team1} vs ${m.team2} @ ${m.date}`);
                }
            } else {
                skipped.push(`Unknown Team: ${m.team1} or ${m.team2}`);
            }
        }

        if (matchesToInsert.length > 0) {
            const operations: any[] = [];

            for (const m of matchesToInsert) {
                const startAt = new Date(m.startTime);
                const autoVersion = await resolveVersionForPayload({
                    startTime: startAt,
                    tournament: m.tournament,
                });

                operations.push(
                    prisma.match.create({
                        data: {
                            startTime: startAt,
                            teamAId: m.teamAId,
                            teamBId: m.teamBId,
                            status: m.status,
                            format: m.format,
                            tournament: m.tournament,
                            stage: m.stage,
                            gameVersion: autoVersion || null,
                        }
                    })
                );
            }

            await prisma.$transaction(operations);
        }
        revalidatePath('/schedule');
        revalidatePath('/admin/schedule');

        return {
            success: true,
            count: matchesToInsert.length,
            skippedCount: skipped.length,
            message: `Imported ${matchesToInsert.length} matches. Skipped ${skipped.length}.`
        };

    } catch (e: any) {
        return { success: false, error: e.message };
    }
}

export async function generatePlayoffBracket(
    tournament: string,
    nodes: {
        startTime: string,
        stage: string,
        format: string,
        teamAId: string | null,
        teamBId: string | null
    }[]
) {
    try {
        if (!nodes || nodes.length === 0) {
            return { success: false, error: 'No matches provided.' };
        }

        const operations: any[] = [];

        for (const n of nodes) {
            const startAt = new Date(n.startTime);
            const autoVersion = await resolveVersionForPayload({
                startTime: startAt,
                tournament,
            });

            operations.push(
                prisma.match.create({
                    data: {
                        startTime: startAt,
                        teamAId: n.teamAId,
                        teamBId: n.teamBId,
                        status: 'SCHEDULED',
                        format: n.format || 'BO5',
                        tournament,
                        stage: n.stage,
                        gameVersion: autoVersion || null,
                    }
                })
            );
        }

        await prisma.$transaction(operations);

        revalidatePath('/schedule');
        revalidatePath('/admin/schedule');
        return { success: true, count: nodes.length };

    } catch (e: any) {
        return { success: false, error: e.message };
    }
}

