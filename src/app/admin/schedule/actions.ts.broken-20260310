        await prisma.match.update({
            where: { id: matchId },
            data: { stage: stageValue },
        });

        await revalidateMatchViews(matchId);
        return { success: true };
    } catch (e: any) {
        return { success: false, error: e.message };
    }
}

export async function bulkUpdateMatches(
    matchIds: string[],
    updates: {
        tournament?: string;
        stage?: string;
        format?: string;
        status?: string;
        gameVersion?: string | null;
    },
) {
    try {
        const ids = (matchIds || []).filter(Boolean);
        if (ids.length === 0) return { success: false, error: 'No matches selected.' };
        if (ids.length > 2000) return { success: false, error: 'Too many matches in one batch.' };

        const data: Record<string, any> = {};

        if (typeof updates.tournament === 'string' && updates.tournament.trim()) {
            data.tournament = updates.tournament.trim();
        }
        if (typeof updates.stage === 'string' && updates.stage.trim()) {
            data.stage = updates.stage.trim();
        }
        if (typeof updates.format === 'string' && updates.format.trim()) {
            data.format = updates.format.trim().toUpperCase();
        }
        if (typeof updates.status === 'string' && updates.status.trim()) {
            data.status = updates.status.trim().toUpperCase();
        }
        if (updates.gameVersion !== undefined) {
            data.gameVersion = trimOptional(updates.gameVersion);
        }

        const keys = Object.keys(data);
        if (keys.length === 0) return { success: false, error: 'No valid update fields.' };

        const result = await prisma.match.updateMany({
            where: { id: { in: ids } },
            data,
        });

        await revalidateMatchViews();
        return { success: true, count: result.count };
    } catch (e: any) {
        return { success: false, error: e.message };
    }
